#!/usr/bin/env bash
# Nova AI Platform — Start Script
# Brings up every Nova service per the current .env. Idempotent — safe to
# re-run after a reboot, after `docker compose down`, or whenever you need
# Nova back online without the development hot-reload loop.
#
# This is NOT the development flow. For dev with Vite hot-reload use:
#   make dev
#
# For first-time install (writes .env, asks mode, etc.) use:
#   ./install
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}"

usage() {
  cat <<USAGE
Nova AI Platform — Start

Production-style boot-up. Builds any missing images, starts every service
detached per the active inference mode in .env, waits for the orchestrator
to report healthy, and prints the access URLs. Designed to be idempotent
so you can re-run it after a host reboot or after \`make down\`.

If you've never run ./install, .env doesn't exist yet — this script will
tell you to run that first instead of guessing.

Usage:
  ./start [options]

Options:
  --rebuild       Force a fresh image build (--no-cache) before starting
  --no-build      Skip the build step entirely (use whatever images exist)
  --foreground    Tail combined logs in the foreground after services are up
  --help, -h      Show this help message and exit
USAGE
}

REBUILD=false
NO_BUILD=false
FOREGROUND=false
for arg in "$@"; do
  case "$arg" in
    --rebuild)         REBUILD=true ;;
    --no-build)        NO_BUILD=true ;;
    --foreground|-f)   FOREGROUND=true ;;
    --help|-h|-help)   usage; exit 0 ;;
    *)                 echo "Unknown option: $arg" >&2
                       echo "Run with --help for usage." >&2
                       exit 2 ;;
  esac
done

# ── Color helpers (TTY only) ─────────────────────────────────────────────────
if [ -t 1 ]; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  RED=""; GREEN=""; YELLOW=""; BOLD=""; DIM=""; RESET=""
fi

step() { echo "${BOLD}$*${RESET}"; }
ok()   { echo "  ${GREEN}✓${RESET} $*"; }
fail() { echo "  ${RED}✗${RESET} $*" >&2; }

# ── Sanity check ─────────────────────────────────────────────────────────────
if [ ! -f "${PROJECT_ROOT}/.env" ]; then
  fail "No .env file found at ${PROJECT_ROOT}/.env"
  echo "    Looks like a fresh checkout. Run ${BOLD}./install${RESET} first to configure Nova."
  exit 1
fi

if ! command -v docker >/dev/null 2>&1 || ! docker info >/dev/null 2>&1; then
  fail "Docker is not running."
  echo "    Start Docker Desktop / the docker daemon and try again."
  exit 1
fi

cd "${PROJECT_ROOT}"

# ── Build ────────────────────────────────────────────────────────────────────
if [ "$NO_BUILD" = "true" ]; then
  step "Skipping build (--no-build)"
elif [ "$REBUILD" = "true" ]; then
  step "Rebuilding all images (--rebuild)..."
  make build BUILD_ARGS=--no-cache 2>&1 | tail -20 || true
  ok "Rebuild complete"
else
  step "Building any missing images..."
  make build 2>&1 | tail -10 || true
  ok "Build step complete"
fi

# ── Start ────────────────────────────────────────────────────────────────────
step "Starting services..."
# `make up` honors GPU overlay + voice profile + INFERENCE_PROFILE from .env
make up 2>&1 | tail -15 || {
  fail "make up failed"
  echo "    Check ${BOLD}make logs${RESET} for details."
  exit 1
}
ok "Compose up dispatched"

# ── Wait for the orchestrator (proxy for "everything is healthy") ────────────
step "Waiting for services to be ready..."
deadline=$(( $(date +%s) + 180 ))
ready=false
while [ $(date +%s) -lt $deadline ]; do
  if curl -sf -m 2 http://localhost:8000/health/ready >/dev/null 2>&1; then
    ready=true
    break
  fi
  sleep 3
done

if [ "$ready" = "true" ]; then
  ok "Orchestrator is healthy"
else
  fail "Timed out waiting for orchestrator (180s)."
  echo "    Inspect: ${BOLD}make logs${RESET} or ${BOLD}make ps${RESET}"
  exit 1
fi

# ── Report ───────────────────────────────────────────────────────────────────
echo
echo "${GREEN}${BOLD}✓ Nova is running.${RESET}"
echo
echo "  ${BOLD}Dashboard:${RESET}  http://localhost:3000"
echo "  ${BOLD}Chat UI:${RESET}    http://localhost:8080"
echo "  ${BOLD}API docs:${RESET}   http://localhost:8000/docs (orchestrator)"
echo
echo "  ${DIM}Logs:       make logs${RESET}"
echo "  ${DIM}Stop:       make down${RESET}"
echo "  ${DIM}Uninstall:  ./uninstall${RESET}"
echo

# ── Optional foreground log tail ─────────────────────────────────────────────
if [ "$FOREGROUND" = "true" ]; then
  echo "${DIM}Tailing logs (--foreground). Ctrl-C to detach.${RESET}"
  exec make logs
fi
