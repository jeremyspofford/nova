{
  "uid": "nova-operations",
  "title": "Nova Operations",
  "description": "Pipeline throughput, spend, and whether Nova's messages actually go anywhere.",
  "tags": ["nova"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tasks (24h)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Tasks\" FROM tasks WHERE created_at > now() - interval '24 hours';"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "none" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed (24h)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Failed\" FROM tasks WHERE created_at > now() - interval '24 hours' AND status = 'failed';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 1 },
              { "color": "#ef4444", "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Spend (24h)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(total_cost_usd), 0) AS \"Spend\" FROM tasks WHERE created_at > now() - interval '24 hours';"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "currencyUSD", "decimals": 2 },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Inbox unread",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Unread\" FROM notify_log WHERE read_at IS NULL;"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "none" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline spend per hour",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(created_at, '1h') AS time, SUM(total_cost_usd) AS \"USD\" FROM tasks WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#14b8a6" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 12, "spanNulls": false },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Push deliveries per hour",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(created_at, '1h') AS time, CASE WHEN ok THEN 'accepted' ELSE 'not delivered' END AS metric, COUNT(*) AS value FROM notify_log WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 65,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "accepted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "not delivered" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent deliveries (receipts)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT created_at AS \"When\", event AS \"Event\", title AS \"Title\", ok AS \"Accepted\", detail AS \"Detail\" FROM notify_log ORDER BY created_at DESC LIMIT 25;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
