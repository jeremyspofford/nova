{
  "uid": "nova-autonomy",
  "title": "Nova Autonomy",
  "description": "The brain at work: standing goals, task dispatch, and what Nova learned.",
  "tags": ["nova"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active goals",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Active goals\" FROM goals WHERE status = 'active';"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "none" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scheduled goals armed",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Armed schedules\" FROM goals WHERE status = 'active' AND schedule_cron IS NOT NULL AND schedule_next_at IS NOT NULL;"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "none" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Reflections (7d)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Reflections\" FROM cortex_reflections WHERE created_at > now() - interval '7 days';"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#14b8a6" }, "unit": "none" },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Standing schedules (UTC)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT title AS \"Goal\", schedule_cron AS \"Cron\", schedule_next_at AS \"Next fire\", schedule_last_ran_at AS \"Last ran\" FROM goals WHERE schedule_cron IS NOT NULL ORDER BY schedule_next_at NULLS LAST;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tasks created per hour, by status",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(created_at, '1h') AS time, status AS metric, COUNT(*) AS value FROM tasks WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 65,
            "lineWidth": 0,
            "stacking": { "mode": "normal" },
            "barAlignment": 0
          },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "complete" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "cancelled" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#a8a29e" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Reflection outcomes per day",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(created_at, '1d') AS time, outcome AS metric, COUNT(*) AS value FROM cortex_reflections WHERE $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 65,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "partial" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent reflections — what Nova learned",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "postgres", "uid": "nova-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT created_at AS \"When\", outcome AS \"Outcome\", LEFT(approach, 100) AS \"Approach\", COALESCE(lesson, '') AS \"Lesson\", COALESCE(failure_mode, '') AS \"Failure mode\" FROM cortex_reflections ORDER BY created_at DESC LIMIT 25;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
