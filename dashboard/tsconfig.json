{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/api.ts",
    "src/router.ts",
    "src/hooks/useServiceHealth.ts",
    "src/hooks/useConversation.ts",
    "src/hooks/useWebSocket.ts",
    "src/components/Layout.tsx",
    "src/components/ServiceStatusDot.tsx",
    "src/components/ToolApprovalCard.tsx",
    "src/components/ConversationView.tsx",
    "src/components/SetupCards.tsx",
    "src/components/TaskDetail.tsx",
    "src/components/ScheduleForm.tsx",
    "src/pages/Chat.tsx",
    "src/pages/Tasks.tsx",
    "src/pages/Memory.tsx",
    "src/pages/Schedules.tsx",
    "src/pages/Settings.tsx",
    "src/pages/settings/AIModelsSection.tsx",
    "src/pages/settings/ExtensionsSection.tsx",
    "src/pages/settings/SecretsSection.tsx",
    "src/pages/settings/SystemSection.tsx",
    "src/contexts/ConversationContext.tsx"
  ]
}
