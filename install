#!/usr/bin/env bash
# Nova AI Platform — Interactive Install Wizard
# Compatible with bash 3.2+ (macOS default). No associative arrays.
set -uo pipefail

usage() {
  cat <<USAGE
Nova AI Platform — Install Wizard

Interactive setup for Nova. Walks you through:
  • Prerequisites check (Docker, Docker Compose, ports)
  • Inference mode selection (hybrid / local-only / cloud-only)
  • Optional cloud-provider API key entry (Groq, Cerebras, Gemini, ChatGPT)
  • Remote access configuration (Cloudflare Tunnel or Tailscale, optional)
  • Writing .env, hardware detection, image build, model pulls, service start

Run from the cloned repo root:
  ./install

After install, change inference mode / target / models from the dashboard
(Settings → AI & Models). To remove Nova entirely later: ./uninstall.

Options:
  --help, -h     Show this help message and exit
USAGE
}

for arg in "$@"; do
  case "$arg" in
    --help|-h|-help) usage; exit 0 ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${SCRIPT_DIR}"
ENV_FILE="${PROJECT_ROOT}/.env"
ENV_EXAMPLE="${PROJECT_ROOT}/.env.example"

# ── Collected config ──────────────────────────────────────────────────────────
CFG_MODE=""              # 1=all-in-one, 2=cloud-only, 3=remote-gpu, 4=host-native
CFG_PROVIDER=""          # groq, cerebras, gemini, chatgpt, skip
CFG_API_KEY=""
CFG_REMOTE_IP=""
CFG_REMOTE_MAC=""
CFG_BROADCAST_IP=""
CFG_ADMIN_SECRET=""
CFG_POSTGRES_PASSWORD=""
CFG_REMOTE_ACCESS=""     # none, cloudflare-tunnel, tailscale
CFG_TUNNEL_TOKEN=""
CFG_TAILSCALE_KEY=""
CFG_OLLAMA_MODELS_DIR="" # bundled Ollama model store (mode 1)
CFG_GPU_OVERLAY="false"  # write COMPOSE_FILE GPU overlay line (mode 1 + NVIDIA)

# ── Colors ────────────────────────────────────────────────────────────────────
BOLD="\033[1m"
DIM="\033[2m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
CYAN="\033[36m"
RESET="\033[0m"

ok()   { printf "  ${GREEN}✓${RESET} %s\n" "$1"; }
warn() { printf "  ${YELLOW}!${RESET} %s\n" "$1"; }
fail() { printf "  ${RED}✗${RESET} %s\n" "$1"; }

# ── Helpers ───────────────────────────────────────────────────────────────────
prompt() {
  local msg="$1" default="$2" var="$3"
  if [ -n "${default}" ]; then
    printf "${BOLD}%s${RESET} [${DIM}%s${RESET}]: " "${msg}" "${default}"
  else
    printf "${BOLD}%s${RESET}: " "${msg}"
  fi
  read -r input
  eval "${var}=\"\${input:-\${default}}\""
}

prompt_secret() {
  local msg="$1" default="$2" var="$3"
  if [ -n "${default}" ]; then
    printf "${BOLD}%s${RESET} [${DIM}********${RESET}]: " "${msg}"
  else
    printf "${BOLD}%s${RESET}: " "${msg}"
  fi
  read -rs input
  echo ""
  eval "${var}=\"\${input:-\${default}}\""
}

random_string() {
  # Generate a random alphanumeric string (works on macOS and Linux)
  local len="${1:-16}"
  LC_ALL=C tr -dc 'a-zA-Z0-9' < /dev/urandom 2>/dev/null | head -c "${len}" || \
    od -An -tx1 -N"${len}" /dev/urandom | tr -d ' \n' | head -c "${len}"
}

# ── Parse existing .env into shell variables (prefix EXISTING_) ──────────────
parse_existing_env() {
  if [ ! -f "${ENV_FILE}" ]; then
    return
  fi
  while IFS= read -r line; do
    # Skip comments and blank lines
    case "${line}" in
      '#'*|'') continue ;;
    esac
    # Only process lines with =
    case "${line}" in
      *=*)
        local key val
        key="${line%%=*}"
        val="${line#*=}"
        # Strip inline comments (but not inside quoted values)
        case "${val}" in
          \"*\"|\'*\') ;; # quoted — keep as-is
          *) val="${val%%#*}"; val="$(echo "${val}" | sed 's/[[:space:]]*$//')" ;;
        esac
        eval "EXISTING_${key}=\"\${val}\""
        ;;
    esac
  done < "${ENV_FILE}"
}

get_existing() {
  eval "echo \"\${EXISTING_$1:-$2}\""
}

# ── Port check (works on macOS lsof, Linux ss, /dev/tcp fallback) ────────────
check_port() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -iTCP:"${port}" -sTCP:LISTEN -P -n >/dev/null 2>&1 && return 0
  elif command -v ss >/dev/null 2>&1; then
    ss -tlnp 2>/dev/null | grep -q ":${port} " && return 0
  else
    (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null && return 0
  fi
  return 1
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 0: Existing Config Detection
# ══════════════════════════════════════════════════════════════════════════════
step_existing_config() {
  if [ ! -f "${ENV_FILE}" ]; then
    return 0  # No config — run full wizard
  fi

  echo ""
  printf "${BOLD}Nova is already configured${RESET} (.env exists).\n"
  echo ""
  echo "  1) Reconfigure  — Walk through setup again (current values as defaults)"
  echo "  2) Start Nova   — Launch with existing config"
  echo "  3) Stop Nova    — Shut down all services"
  echo ""
  prompt "Choice" "2" choice

  case "${choice}" in
    1)
      parse_existing_env
      return 0  # Continue to wizard
      ;;
    3)
      echo ""
      echo "Stopping Nova..."
      cd "${PROJECT_ROOT}" && docker compose down
      echo ""
      ok "Nova stopped."
      exit 0
      ;;
    *)
      echo ""
      echo "Starting Nova..."
      exec "${PROJECT_ROOT}/scripts/install.sh"
      ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 1: Pre-flight Checks
# ══════════════════════════════════════════════════════════════════════════════
step_preflight() {
  echo ""
  printf "${BOLD}Checking prerequisites...${RESET}\n"

  # Docker
  if ! command -v docker >/dev/null 2>&1; then
    fail "Docker not found"
    echo ""
    echo "  Install Docker Desktop from: https://docker.com/products/docker-desktop"
    exit 1
  fi
  local docker_ver
  docker_ver="$(docker --version 2>/dev/null | sed 's/Docker version \([^,]*\).*/\1/')"
  ok "Docker ${docker_ver}"

  # Docker Compose
  if ! docker compose version >/dev/null 2>&1; then
    fail "Docker Compose not found"
    echo "  Docker Compose v2 is required. Update Docker Desktop or install the plugin."
    exit 1
  fi
  local compose_ver
  compose_ver="$(docker compose version 2>/dev/null | sed 's/.*v\{0,1\}\([0-9][0-9.]*\).*/\1/')"
  ok "Docker Compose v${compose_ver}"

  # Disk space
  local free_gb
  if [ "$(uname)" = "Darwin" ]; then
    free_gb="$(df -g "${PROJECT_ROOT}" 2>/dev/null | awk 'NR==2{print $4}')"
  else
    free_gb="$(df -BG "${PROJECT_ROOT}" 2>/dev/null | awk 'NR==2{gsub("G",""); print $4}')"
  fi
  if [ -n "${free_gb:-}" ] && [ "${free_gb}" -gt 0 ] 2>/dev/null; then
    if [ "${free_gb}" -lt 4 ]; then
      warn "${free_gb} GB disk free (recommend at least 4 GB)"
    else
      ok "${free_gb} GB disk free"
    fi
  fi

  # Port checks
  local ports="5432 6379 8000 8001 8002 8080 3001 8888"
  local conflicts=""
  for port in ${ports}; do
    if check_port "${port}"; then
      conflicts="${conflicts} ${port}"
    fi
  done
  if [ -n "${conflicts}" ]; then
    warn "Ports in use:${conflicts} (may be a previous Nova run)"
  else
    ok "All ports available"
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 2: Deployment Mode
# ══════════════════════════════════════════════════════════════════════════════
step_mode() {
  echo ""
  printf "${BOLD}How will you run Nova?${RESET}\n"
  echo ""
  echo "  1) All-in-one    — Nova runs Ollama in a container on this machine (simplest)"
  echo "  2) Cloud only    — No local AI models, use cloud APIs only"
  echo "  3) Remote GPU    — This machine runs Nova, a separate PC runs AI models"
  echo "  4) Host native   — Ollama runs on this machine outside Docker (or Windows host in WSL2)"
  echo ""

  # Detect current mode as default
  local default="1"
  local existing_profiles
  existing_profiles="$(get_existing COMPOSE_PROFILES "")"
  local existing_ollama_url
  existing_ollama_url="$(get_existing OLLAMA_BASE_URL "")"
  local existing_strategy
  existing_strategy="$(get_existing LLM_ROUTING_STRATEGY "")"

  if [ "${existing_strategy}" = "cloud-only" ]; then
    default="2"
  elif [ "${existing_ollama_url}" = "host" ]; then
    default="4"
  elif [ -n "${existing_ollama_url}" ] && [ "${existing_ollama_url}" != "http://ollama:11434" ]; then
    default="3"
  elif echo "${existing_profiles}" | grep -q "inference-ollama" 2>/dev/null; then
    default="1"
  fi

  prompt "Choice" "${default}" CFG_MODE
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 3: AI Provider
# ══════════════════════════════════════════════════════════════════════════════
step_provider() {
  echo ""

  local required=false
  local label="Pick a cloud AI provider"
  case "${CFG_MODE}" in
    1|4) label="Add a cloud backup provider? (press Enter to skip)" ;;
    2) label="Pick a cloud AI provider (required)"; required=true ;;
    3) label="Add a cloud fallback? (recommended in case GPU box is off)" ;;
  esac

  printf "${BOLD}%s${RESET}\n" "${label}"
  echo ""
  echo "  1) Groq        — Free, 14,400 req/day           https://console.groq.com"
  echo "  2) Cerebras    — Free, 1M tokens/day             https://cloud.cerebras.ai"
  echo "  3) Gemini      — Free, 250 req/day               https://aistudio.google.com"
  echo "  4) ChatGPT     — Uses your chatgpt.com subscription"
  if [ "${required}" = "false" ]; then
    echo "  5) Skip for now"
  fi
  echo ""

  local default="1"
  if [ "${required}" = "false" ] && ([ "${CFG_MODE}" = "1" ] || [ "${CFG_MODE}" = "4" ]); then
    default="5"
  fi

  # Detect existing provider as default
  local existing_groq existing_cerebras existing_gemini existing_chatgpt
  existing_groq="$(get_existing GROQ_API_KEY "")"
  existing_cerebras="$(get_existing CEREBRAS_API_KEY "")"
  existing_gemini="$(get_existing GEMINI_API_KEY "")"
  existing_chatgpt="$(get_existing CHATGPT_ACCESS_TOKEN "")"

  if [ -n "${existing_groq}" ]; then default="1"
  elif [ -n "${existing_cerebras}" ]; then default="2"
  elif [ -n "${existing_gemini}" ]; then default="3"
  elif [ -n "${existing_chatgpt}" ]; then default="4"
  fi

  prompt "Choice" "${default}" provider_choice

  case "${provider_choice}" in
    1) CFG_PROVIDER="groq"
       echo ""
       prompt_secret "Paste your Groq API key" "$(get_existing GROQ_API_KEY "")" CFG_API_KEY
       ;;
    2) CFG_PROVIDER="cerebras"
       echo ""
       prompt_secret "Paste your Cerebras API key" "$(get_existing CEREBRAS_API_KEY "")" CFG_API_KEY
       ;;
    3) CFG_PROVIDER="gemini"
       echo ""
       prompt_secret "Paste your Gemini API key" "$(get_existing GEMINI_API_KEY "")" CFG_API_KEY
       ;;
    4) CFG_PROVIDER="chatgpt"
       echo ""
       echo "  Run: codex login  (token auto-read from ~/.codex/auth.json)"
       prompt_secret "Paste your access token (or press Enter for auto-detect)" "$(get_existing CHATGPT_ACCESS_TOKEN "")" CFG_API_KEY
       ;;
    5|"")
       if [ "${required}" = "true" ]; then
         warn "Cloud-only mode requires at least one provider."
         step_provider
         return
       fi
       CFG_PROVIDER="skip"
       CFG_API_KEY=""
       ;;
    *)
       CFG_PROVIDER="skip"
       CFG_API_KEY=""
       ;;
  esac

  if [ -n "${CFG_API_KEY}" ]; then
    ok "Key saved"
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 3b: Bundled Inference Details (mode 1)
# ══════════════════════════════════════════════════════════════════════════════
step_bundled() {
  if [ "${CFG_MODE}" != "1" ]; then
    return
  fi

  echo ""
  printf "${BOLD}Bundled Ollama Setup${RESET}\n"
  echo ""

  # Port collision: a host-run Ollama already owns 11434, which the bundled
  # container also publishes for CLI access.
  if curl -sf -m 2 "http://localhost:11434/api/tags" >/dev/null 2>&1; then
    warn "An Ollama server is already running on this machine (port 11434)."
    echo "     The bundled container can't bind the same port. Either pick"
    echo "     mode 4 (Host native) to use the existing server, or stop it."
    echo ""
    prompt "Continue with the bundled container anyway? [y/N]" "n" bundled_continue
    case "$(echo "${bundled_continue}" | tr 'A-Z' 'a-z')" in
      y|yes) ;;
      *) step_mode; step_provider; step_bundled; return ;;
    esac
  fi

  # Model storage: fresh default under ./data, or reuse an existing store.
  local default_models_dir
  default_models_dir="$(get_existing OLLAMA_MODELS_DIR "")"
  if [ -z "${default_models_dir}" ]; then
    if [ -d "${HOME}/.ollama/models" ]; then
      default_models_dir="${HOME}/.ollama"
      echo "  Found an existing Ollama model store at ~/.ollama — reusing it"
      echo "  avoids re-downloading models. Press Enter to reuse, or type a path."
    else
      default_models_dir="./data/models/ollama"
    fi
  fi
  prompt "Model storage directory" "${default_models_dir}" CFG_OLLAMA_MODELS_DIR

  # GPU detection → compose overlay. Only written on positive detection;
  # activating it without nvidia-container-toolkit hard-fails compose up.
  CFG_GPU_OVERLAY="false"
  if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi >/dev/null 2>&1; then
    if docker info 2>/dev/null | grep -qi nvidia; then
      CFG_GPU_OVERLAY="true"
      ok "NVIDIA GPU detected — enabling GPU acceleration for bundled inference"
    else
      warn "NVIDIA GPU found but Docker's nvidia runtime is missing."
      echo "     Install nvidia-container-toolkit to GPU-accelerate bundled"
      echo "     inference; continuing CPU-only for now."
    fi
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 4: Remote GPU Details
# ══════════════════════════════════════════════════════════════════════════════
step_remote() {
  if [ "${CFG_MODE}" != "3" ]; then
    return
  fi

  # Mode 4 (host native) doesn't need remote IP — URL is just "host"
  # This block only runs for mode 3 (remote GPU)

  echo ""
  printf "${BOLD}Remote Ollama Setup${RESET}\n"
  echo ""

  local default_ip
  default_ip="$(get_existing OLLAMA_BASE_URL "" | sed 's|http://||;s|:11434||')"

  prompt "IP address or hostname of your GPU machine" "${default_ip}" CFG_REMOTE_IP

  # Test connection
  printf "  Testing connection... "
  if curl -sf "http://${CFG_REMOTE_IP}:11434/api/tags" >/dev/null 2>&1; then
    local models
    models="$(curl -sf "http://${CFG_REMOTE_IP}:11434/api/tags" 2>/dev/null | \
      python3 -c "import sys,json; print(', '.join(m['name'] for m in json.load(sys.stdin).get('models',[])))" 2>/dev/null || echo "unknown")"
    printf "${GREEN}✓${RESET} Ollama online (${models})\n"
  else
    printf "${YELLOW}!${RESET} Not reachable (OK if it's powered off)\n"
  fi

  echo ""
  local default_wol="n"
  if [ -n "$(get_existing WOL_MAC_ADDRESS "")" ]; then
    default_wol="y"
  fi

  prompt "Enable Wake-on-LAN to auto-wake it? [y/N]" "${default_wol}" wol_choice

  case "$(echo "${wol_choice}" | tr 'A-Z' 'a-z')" in
    y|yes)
      echo ""
      prompt "MAC address (check your router or run 'ip link' on the GPU box)" \
        "$(get_existing WOL_MAC_ADDRESS "")" CFG_REMOTE_MAC

      # Derive broadcast default from IP
      local default_broadcast
      default_broadcast="$(get_existing WOL_BROADCAST_IP "")"
      if [ -z "${default_broadcast}" ] && [ -n "${CFG_REMOTE_IP}" ]; then
        default_broadcast="$(echo "${CFG_REMOTE_IP}" | sed 's/\.[0-9]*$/.255/')"
      fi

      prompt "LAN broadcast IP" "${default_broadcast}" CFG_BROADCAST_IP
      ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 5: Admin Password
# ══════════════════════════════════════════════════════════════════════════════
step_admin() {
  echo ""
  local existing_secret
  existing_secret="$(get_existing NOVA_ADMIN_SECRET "")"
  local default_secret="${existing_secret}"

  printf "${BOLD}Dashboard admin password${RESET} (press Enter to "
  if [ -n "${default_secret}" ] && [ "${default_secret}" != "nova-admin-secret-change-me" ]; then
    printf "keep current"
  else
    printf "generate one"
    default_secret=""
  fi
  printf ")\n"

  prompt_secret "> " "${default_secret}" CFG_ADMIN_SECRET

  if [ -z "${CFG_ADMIN_SECRET}" ]; then
    CFG_ADMIN_SECRET="nova-$(random_string 12)"
  fi

  ok "Saved (you can change this later in Settings)"

  # Postgres password
  CFG_POSTGRES_PASSWORD="$(get_existing POSTGRES_PASSWORD "")"
  if [ -z "${CFG_POSTGRES_PASSWORD}" ] || [ "${CFG_POSTGRES_PASSWORD}" = "nova_dev_password" ]; then
    CFG_POSTGRES_PASSWORD="$(random_string 24)"
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 6: Remote Access
# ══════════════════════════════════════════════════════════════════════════════
step_remote_access() {
  echo ""
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"
  printf "${BOLD}  Remote Access (optional)${RESET}\n"
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"
  echo ""
  printf "How would you like to access Nova remotely?\n"
  echo ""
  echo "  1) None — local network only (default)"
  echo "  2) Cloudflare Tunnel — access from any browser, automatic HTTPS"
  echo "     Requires: domain name + free Cloudflare account"
  echo "  3) Tailscale — private VPN mesh, fully encrypted"
  echo "     Requires: free Tailscale account + app on each device"
  echo ""

  local default="1"
  local existing_profiles
  existing_profiles="$(get_existing COMPOSE_PROFILES "")"
  if echo "${existing_profiles}" | grep -q "cloudflare-tunnel" 2>/dev/null; then
    default="2"
  elif echo "${existing_profiles}" | grep -q "tailscale" 2>/dev/null; then
    default="3"
  fi

  prompt "Choice" "${default}" remote_choice

  case "${remote_choice}" in
    2)
      CFG_REMOTE_ACCESS="cloudflare-tunnel"
      echo ""
      echo "  Create a tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels"
      echo "  Point it to: http://dashboard:3000 (Docker internal hostname)"
      echo ""
      prompt_secret "Paste your Cloudflare Tunnel token" "$(get_existing CLOUDFLARE_TUNNEL_TOKEN "")" CFG_TUNNEL_TOKEN
      if [ -n "${CFG_TUNNEL_TOKEN}" ]; then
        ok "Tunnel token saved"
      else
        warn "No token — you can add CLOUDFLARE_TUNNEL_TOKEN to .env later"
      fi
      ;;
    3)
      CFG_REMOTE_ACCESS="tailscale"
      echo ""
      echo "  Create an auth key at: https://login.tailscale.com/admin/settings/keys"
      echo "  Install Tailscale on your phone/laptop to access Nova"
      echo ""
      prompt_secret "Paste your Tailscale auth key" "$(get_existing TAILSCALE_AUTHKEY "")" CFG_TAILSCALE_KEY
      if [ -n "${CFG_TAILSCALE_KEY}" ]; then
        ok "Tailscale auth key saved"
      else
        warn "No key — you can add TAILSCALE_AUTHKEY to .env later"
      fi
      ;;
    *)
      CFG_REMOTE_ACCESS="none"
      ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
# Write .env
# ══════════════════════════════════════════════════════════════════════════════
write_env() {
  # Determine mode-specific values
  local compose_profiles="" ollama_url="" routing_strategy="" default_model="" inference_mode=""

  case "${CFG_MODE}" in
    1) # All-in-one — bundled Ollama container (compose profile)
      compose_profiles="inference-ollama"
      ollama_url="http://ollama:11434"
      routing_strategy="local-first"
      default_model="qwen2.5:7b"
      inference_mode="hybrid"
      ;;
    2) # Cloud-only
      compose_profiles=""
      routing_strategy="cloud-only"
      inference_mode="cloud-only"
      case "${CFG_PROVIDER}" in
        groq)       default_model="groq/llama-3.3-70b-versatile" ;;
        cerebras)   default_model="cerebras/llama3.1-8b" ;;
        gemini)     default_model="gemini/gemini-2.5-flash" ;;
        chatgpt)    default_model="chatgpt/gpt-4o" ;;
        *)          default_model="groq/llama-3.3-70b-versatile" ;;
      esac
      ;;
    3) # Remote GPU — hybrid mode pointing at an external Ollama
      compose_profiles=""
      ollama_url="http://${CFG_REMOTE_IP}:11434"
      routing_strategy="local-first"
      default_model="qwen2.5:7b"
      inference_mode="hybrid"
      ;;
    4) # Host native — hybrid mode pointing at host's Ollama
      compose_profiles=""
      ollama_url="host"
      routing_strategy="local-first"
      default_model="qwen2.5:7b"
      inference_mode="hybrid"
      ;;
  esac

  # ── Preserve runtime-owned profile slices across re-runs ───────────────────
  # COMPOSE_PROFILES is regenerated from the deployment mode, but the Nova UI
  # owns two slices of it at runtime and we must not clobber them on re-install:
  #   • bundled inference — Settings/Models → Local Inference start/stop writes
  #     inference-* profiles; the toggle is the source of truth.
  #   • optional workers  — browser / voice / knowledge / observability, etc.
  # The mode still decides the local-vs-cloud DIRECTION (mode 1 = bundled,
  # modes 2/3/4 = none), but within "bundled" the toggle's current selection
  # wins over re-seeding inference-ollama.
  local existing_profiles_now preserved_other="" existing_inference="" _oldifs="${IFS}"
  existing_profiles_now="$(get_existing COMPOSE_PROFILES "")"
  IFS=','
  for _p in ${existing_profiles_now}; do
    _p="$(echo "${_p}" | tr -d '[:space:]')"
    case "${_p}" in
      ''|cloudflare-tunnel|tailscale) ;;                                   # remote-access: recomputed below
      inference-*) existing_inference="${existing_inference:+${existing_inference},}${_p}" ;;
      *) preserved_other="${preserved_other:+${preserved_other},}${_p}" ;; # browser/voice/knowledge/…
    esac
  done
  IFS="${_oldifs}"

  # If the mode wants bundled inference and the toggle already picked something,
  # honor the toggle instead of forcing the mode default (inference-ollama).
  case "${compose_profiles}" in
    *inference-*)
      if [ -n "${existing_inference}" ]; then
        compose_profiles="${existing_inference}"
      fi
      ;;
  esac

  # Always carry forward non-inference worker profiles the user enabled at runtime.
  if [ -n "${preserved_other}" ]; then
    compose_profiles="${compose_profiles:+${compose_profiles},}${preserved_other}"
  fi

  # Append remote access profile
  if [ "${CFG_REMOTE_ACCESS}" = "cloudflare-tunnel" ] || [ "${CFG_REMOTE_ACCESS}" = "tailscale" ]; then
    if [ -n "${compose_profiles}" ]; then
      compose_profiles="${compose_profiles},${CFG_REMOTE_ACCESS}"
    else
      compose_profiles="${CFG_REMOTE_ACCESS}"
    fi
  fi

  # Collect extra lines from existing .env that we don't manage
  local extra_lines=""
  local managed_keys="POSTGRES_PASSWORD NOVA_ADMIN_SECRET COMPOSE_PROFILES OLLAMA_BASE_URL NOVA_INFERENCE_MODE"
  managed_keys="${managed_keys} COMPOSE_FILE OLLAMA_MODELS_DIR"
  managed_keys="${managed_keys} LLM_ROUTING_STRATEGY DEFAULT_CHAT_MODEL WOL_MAC_ADDRESS WOL_BROADCAST_IP"
  managed_keys="${managed_keys} GROQ_API_KEY CEREBRAS_API_KEY GEMINI_API_KEY CHATGPT_ACCESS_TOKEN"
  managed_keys="${managed_keys} REQUIRE_AUTH LOG_LEVEL SHELL_TIMEOUT_SECONDS GEMINI_USE_ADC"
  managed_keys="${managed_keys} CLOUDFLARE_TUNNEL_TOKEN TAILSCALE_AUTHKEY CORS_ALLOWED_ORIGINS"

  if [ -f "${ENV_FILE}" ]; then
    while IFS= read -r line; do
      case "${line}" in
        '#'*|'') continue ;;
      esac
      case "${line}" in
        *=*)
          local key="${line%%=*}"
          local is_managed=false
          for mk in ${managed_keys}; do
            if [ "${key}" = "${mk}" ]; then
              is_managed=true
              break
            fi
          done
          if [ "${is_managed}" = "false" ]; then
            extra_lines="${extra_lines}${line}
"
          fi
          ;;
      esac
    done < "${ENV_FILE}"
  fi

  # Preserve existing values for keys we manage but don't prompt for
  local existing_require_auth existing_log_level existing_shell_timeout existing_gemini_adc
  existing_require_auth="$(get_existing REQUIRE_AUTH "false")"
  existing_log_level="$(get_existing LOG_LEVEL "INFO")"
  existing_shell_timeout="$(get_existing SHELL_TIMEOUT_SECONDS "30")"
  existing_gemini_adc="$(get_existing GEMINI_USE_ADC "false")"

  # Preserve provider keys we didn't ask about
  local existing_groq existing_cerebras existing_gemini existing_chatgpt
  existing_groq="$(get_existing GROQ_API_KEY "")"
  existing_cerebras="$(get_existing CEREBRAS_API_KEY "")"
  existing_gemini="$(get_existing GEMINI_API_KEY "")"
  existing_chatgpt="$(get_existing CHATGPT_ACCESS_TOKEN "")"

  # Apply the user's chosen provider key
  case "${CFG_PROVIDER}" in
    groq)       existing_groq="${CFG_API_KEY}" ;;
    cerebras)   existing_cerebras="${CFG_API_KEY}" ;;
    gemini)     existing_gemini="${CFG_API_KEY}" ;;
    chatgpt)    existing_chatgpt="${CFG_API_KEY}" ;;
  esac

  # Also preserve per-provider default model overrides
  local existing_default_ollama existing_default_groq existing_default_gemini
  local existing_default_cerebras existing_default_chatgpt
  local existing_default_openrouter existing_default_github
  existing_default_ollama="$(get_existing DEFAULT_OLLAMA_MODEL "")"
  existing_default_groq="$(get_existing DEFAULT_GROQ_MODEL "")"
  existing_default_gemini="$(get_existing DEFAULT_GEMINI_MODEL "")"
  existing_default_cerebras="$(get_existing DEFAULT_CEREBRAS_MODEL "")"
  existing_default_chatgpt="$(get_existing DEFAULT_CHATGPT_MODEL "")"
  existing_default_openrouter="$(get_existing DEFAULT_OPENROUTER_MODEL "")"
  existing_default_github="$(get_existing DEFAULT_GITHUB_MODEL "")"

  # Also preserve paid API keys
  local existing_anthropic existing_openai existing_openrouter existing_github
  existing_anthropic="$(get_existing ANTHROPIC_API_KEY "")"
  existing_openai="$(get_existing OPENAI_API_KEY "")"
  existing_openrouter="$(get_existing OPENROUTER_API_KEY "")"
  existing_github="$(get_existing GITHUB_TOKEN "")"

  # Write .env
  cat > "${ENV_FILE}" <<ENVEOF
# Generated by Nova setup wizard — $(date +%Y-%m-%d)
# Run ./install to reconfigure, or edit this file manually.

# ── Core ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=${CFG_POSTGRES_PASSWORD}
NOVA_ADMIN_SECRET=${CFG_ADMIN_SECRET}

# ── Deployment Mode ────────────────────────────────────────────────────────
ENVEOF

  if [ -n "${compose_profiles}" ]; then
    echo "COMPOSE_PROFILES=${compose_profiles}" >> "${ENV_FILE}"
  fi

  if [ -n "${ollama_url}" ]; then
    echo "OLLAMA_BASE_URL=${ollama_url}" >> "${ENV_FILE}"
  fi

  if [ -n "${CFG_OLLAMA_MODELS_DIR}" ]; then
    echo "OLLAMA_MODELS_DIR=${CFG_OLLAMA_MODELS_DIR}" >> "${ENV_FILE}"
  fi

  if [ "${CFG_GPU_OVERLAY}" = "true" ]; then
    echo "COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml" >> "${ENV_FILE}"
  fi

  cat >> "${ENV_FILE}" <<ENVEOF
LLM_ROUTING_STRATEGY=${routing_strategy}
NOVA_INFERENCE_MODE=${inference_mode}
DEFAULT_CHAT_MODEL=${default_model}

# ── Per-provider default models (optional overrides) ──────────────────────
ENVEOF

  [ -n "${existing_default_ollama}" ] && echo "DEFAULT_OLLAMA_MODEL=${existing_default_ollama}" >> "${ENV_FILE}"
  [ -n "${existing_default_groq}" ] && echo "DEFAULT_GROQ_MODEL=${existing_default_groq}" >> "${ENV_FILE}"
  [ -n "${existing_default_gemini}" ] && echo "DEFAULT_GEMINI_MODEL=${existing_default_gemini}" >> "${ENV_FILE}"
  [ -n "${existing_default_cerebras}" ] && echo "DEFAULT_CEREBRAS_MODEL=${existing_default_cerebras}" >> "${ENV_FILE}"
  [ -n "${existing_default_chatgpt}" ] && echo "DEFAULT_CHATGPT_MODEL=${existing_default_chatgpt}" >> "${ENV_FILE}"
  [ -n "${existing_default_openrouter}" ] && echo "DEFAULT_OPENROUTER_MODEL=${existing_default_openrouter}" >> "${ENV_FILE}"
  [ -n "${existing_default_github}" ] && echo "DEFAULT_GITHUB_MODEL=${existing_default_github}" >> "${ENV_FILE}"

  # Wake-on-LAN
  if [ -n "${CFG_REMOTE_MAC}" ]; then
    cat >> "${ENV_FILE}" <<ENVEOF

# ── Wake-on-LAN (remote GPU) ─────────────────────────────────────────────
WOL_MAC_ADDRESS=${CFG_REMOTE_MAC}
WOL_BROADCAST_IP=${CFG_BROADCAST_IP:-255.255.255.255}
ENVEOF
  fi

  # Provider keys
  cat >> "${ENV_FILE}" <<ENVEOF

# ── AI Providers ──────────────────────────────────────────────────────────
# Subscription providers
CHATGPT_ACCESS_TOKEN=${existing_chatgpt}

# Free tier providers (no credit card)
GROQ_API_KEY=${existing_groq}
CEREBRAS_API_KEY=${existing_cerebras}
GEMINI_API_KEY=${existing_gemini}
GEMINI_USE_ADC=${existing_gemini_adc}
OPENROUTER_API_KEY=${existing_openrouter}
GITHUB_TOKEN=${existing_github}

# Paid API keys (billed per token)
ANTHROPIC_API_KEY=${existing_anthropic}
OPENAI_API_KEY=${existing_openai}

# ── Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=${existing_log_level}
REQUIRE_AUTH=${existing_require_auth}
SHELL_TIMEOUT_SECONDS=${existing_shell_timeout}
ENVEOF

  # Remote access tokens
  if [ "${CFG_REMOTE_ACCESS}" = "cloudflare-tunnel" ] && [ -n "${CFG_TUNNEL_TOKEN}" ]; then
    cat >> "${ENV_FILE}" <<ENVEOF

# ── Remote Access ────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=${CFG_TUNNEL_TOKEN}
ENVEOF
  elif [ "${CFG_REMOTE_ACCESS}" = "tailscale" ] && [ -n "${CFG_TAILSCALE_KEY}" ]; then
    cat >> "${ENV_FILE}" <<ENVEOF

# ── Remote Access ────────────────────────────────────────────────────────
TAILSCALE_AUTHKEY=${CFG_TAILSCALE_KEY}
ENVEOF
  fi

  # Append extra lines the user added manually
  if [ -n "${extra_lines}" ]; then
    cat >> "${ENV_FILE}" <<ENVEOF

# ── Custom (preserved from previous config) ──────────────────────────────
ENVEOF
    printf "%s" "${extra_lines}" >> "${ENV_FILE}"
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Step 6: Review & Launch
# ══════════════════════════════════════════════════════════════════════════════
step_summary() {
  echo ""
  echo ""
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"
  printf "${BOLD}  Nova Setup Summary${RESET}\n"
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"
  echo ""

  case "${CFG_MODE}" in
    1) printf "  Mode:          All-in-one (bundled Ollama container)\n" ;;
    2) printf "  Mode:          Cloud only\n" ;;
    3) printf "  Mode:          Remote GPU (${CFG_REMOTE_IP})\n" ;;
    4) printf "  Mode:          Host native (Ollama on this machine)\n" ;;
  esac

  if [ "${CFG_MODE}" = "1" ]; then
    printf "  Model storage: ${CFG_OLLAMA_MODELS_DIR:-./data/models/ollama}\n"
    if [ "${CFG_GPU_OVERLAY}" = "true" ]; then
      printf "  GPU:           NVIDIA (compose overlay enabled)\n"
    else
      printf "  GPU:           none detected (CPU inference)\n"
    fi
  fi

  case "${CFG_PROVIDER}" in
    groq)       printf "  AI provider:   Groq (free tier)\n" ;;
    cerebras)   printf "  AI provider:   Cerebras (free tier)\n" ;;
    gemini)     printf "  AI provider:   Gemini (free tier)\n" ;;
    chatgpt)    printf "  AI provider:   ChatGPT (subscription)\n" ;;
    skip)       printf "  AI provider:   None (local only)\n" ;;
  esac

  if [ -n "${CFG_REMOTE_MAC}" ]; then
    printf "  Wake-on-LAN:   ${CFG_REMOTE_MAC}\n"
  fi

  case "${CFG_REMOTE_ACCESS}" in
    cloudflare-tunnel) printf "  Remote access: Cloudflare Tunnel\n" ;;
    tailscale)         printf "  Remote access: Tailscale VPN\n" ;;
    *)                 printf "  Remote access: None (local only)\n" ;;
  esac

  echo ""
  printf "  Dashboard:     ${CYAN}http://localhost:3001${RESET}\n"
  printf "  Chat UI:       ${CYAN}http://localhost:8080${RESET}\n"
  echo ""
  printf "  Config written to ${DIM}.env${RESET}\n"
  echo ""

  prompt "Start Nova now? [Y/n]" "y" start_choice

  case "$(echo "${start_choice}" | tr 'A-Z' 'a-z')" in
    n|no)
      echo ""
      ok "Config saved. Run ${BOLD}./install${RESET} or ${BOLD}make up${RESET} when ready."
      ;;
    *)
      echo ""
      exec "${PROJECT_ROOT}/scripts/install.sh"
      ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════════════════════
main() {
  echo ""
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"
  printf "${BOLD}  Nova AI Platform — Setup Wizard${RESET}\n"
  printf "${BOLD}═══════════════════════════════════════════════════${RESET}\n"

  step_existing_config
  step_preflight
  step_mode
  step_provider
  step_bundled
  step_remote
  step_admin
  step_remote_access
  write_env
  step_summary
}

main "$@"
