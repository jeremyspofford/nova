#!/usr/bin/env bash
# install — Nova v2 first-time setup
set -euo pipefail

echo "Nova v2 — Install"
echo "=================="

# Check requirements
command -v docker >/dev/null 2>&1 || { echo "Error: docker is required"; exit 1; }
docker compose version >/dev/null 2>&1 || { echo "Error: docker compose v2 is required"; exit 1; }

# Generate .env if missing
if [ ! -f .env ]; then
  echo "Creating .env from .env.example..."
  cp .env.example .env

  # Generate master key
  MASTER_KEY=$(python3 -c "import secrets; print(secrets.token_hex(32))")
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "s/CREDENTIAL_MASTER_KEY=/CREDENTIAL_MASTER_KEY=${MASTER_KEY}/" .env
  else
    sed -i "s/CREDENTIAL_MASTER_KEY=/CREDENTIAL_MASTER_KEY=${MASTER_KEY}/" .env
  fi

  # Prompt for postgres password
  read -rsp "Set a Postgres password: " PG_PASS
  echo
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "s/POSTGRES_PASSWORD=changeme/POSTGRES_PASSWORD=${PG_PASS}/" .env
  else
    sed -i "s/POSTGRES_PASSWORD=changeme/POSTGRES_PASSWORD=${PG_PASS}/" .env
  fi
fi

# Create data dirs
mkdir -p data/postgres data/redis backups

# Build and start
echo "Building services..."
docker compose build

echo "Starting services..."
docker compose up -d

# Wait for health
echo "Waiting for services to be healthy..."
TIMEOUT=120
ELAPSED=0
while [ $ELAPSED -lt $TIMEOUT ]; do
  if curl -sf http://localhost:8000/health/ready >/dev/null 2>&1; then
    echo "Nova is ready. Open http://localhost:3000"
    exit 0
  fi
  sleep 5
  ELAPSED=$((ELAPSED + 5))
  echo "  ...waiting (${ELAPSED}s)"
done

echo "Timeout waiting for Nova. Check logs: docker compose logs"
exit 1
