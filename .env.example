# Nova v2 — copy to .env, fill in real values
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nova

REDIS_URL=redis://redis:6379

CREDENTIAL_MASTER_KEY=

# ── Local inference ───────────────────────────────────────────────────────────
# Backend: ollama-host | ollama | llamacpp | vllm | sglang | lmstudio | none
# ollama-host  — Ollama already running on this machine (set by install wizard)
# ollama       — Ollama runs in Docker (profile: local-ollama)
# llamacpp     — llama.cpp server in Docker (profile: local-llamacpp)
# vllm         — vLLM in Docker, GPU required (profile: local-vllm)
# sglang       — sglang in Docker, GPU required (profile: local-sglang)
# lmstudio     — LM Studio on this machine, provide LOCAL_INFERENCE_URL
# none         — no local backend
# GPU notes (Windows + WSL2 dev):
#  - ollama-host (default): Ollama is the native WINDOWS app and talks to the GPU
#    through the Windows driver — WSL is not in the inference path. If the Models
#    page warns the GPU isn't used: quit/restart Ollama from the Windows tray
#    (it probes GPUs only at startup), update Ollama, verify nvidia-smi works on
#    Windows, then check %LOCALAPPDATA%\Ollama\server.log for GPU detection.
#  - ollama (container, profile local-ollama): needs the GPU passed through —
#    Windows NVIDIA driver -> WSL2 GPU support -> Docker Desktop GPU -> the
#    docker-compose.gpu.yml overlay (auto-applied when nvidia-smi is visible).
#    Verify with: docker compose exec nova-ollama nvidia-smi
NOVA_INFERENCE_BACKEND=ollama-host

# URL the gateway uses to reach the local backend.
# Set automatically by ./install. Override if your setup differs.
# ollama-host default: http://host.docker.internal:11434
# ollama container:    http://nova-ollama:11434
# llamacpp container:  http://nova-llamacpp:8080
# vllm container:      http://nova-vllm:8000
# sglang container:    http://nova-sglang:30000
LOCAL_INFERENCE_URL=http://host.docker.internal:11434

# Model name/ID for the active local backend.
# Ollama: tag name (e.g. llama3.2, mistral)
# llama.cpp: filename in /models volume (e.g. llama-3.2-3b-q4.gguf)
# vLLM / sglang: HuggingFace model ID (e.g. meta-llama/Llama-3.2-3B-Instruct)
# LM Studio: model name as shown in LM Studio's API settings
LOCAL_COMPLETION_MODEL=llama3.2

# Embedding model — Ollama-based backends only
LOCAL_EMBED_MODEL=nomic-embed-text

# vLLM settings (used when NOVA_INFERENCE_BACKEND=vllm)
VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
VLLM_GPU_MEMORY_UTILIZATION=0.9

# sglang settings (used when NOVA_INFERENCE_BACKEND=sglang)
SGLANG_MODEL=meta-llama/Llama-3.2-3B-Instruct

# LLM routing: local-first | local-only | cloud-first | cloud-only
LLM_ROUTING_STRATEGY=local-first

# Memory extraction model — distills chat into structured memories.
# 'auto' uses the default local model; pin a small fast one on CPU-only boxes.
EXTRACTION_MODEL=auto

# Admin API secret — used to gate all /api/v1/* endpoints
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
ADMIN_SECRET=

LOG_LEVEL=INFO
NOVA_WORKSPACE=/workspace

# Active Docker Compose profiles (comma-separated, no spaces).
# Written by ./install. voice is included by default.
# Add: local-ollama, local-llamacpp, local-vllm, or local-sglang as needed.
COMPOSE_PROFILES=voice

# ── Wake-on-LAN (optional) ─────────────────────────────────────────────────────
# Wake a sleeping inference host (e.g. a GPU box) when local routing needs it.
# 1. Add a secret named 'wol_mac' with the host's MAC (Settings → Secrets)
# 2. Add 'wol' to COMPOSE_PROFILES and set:
#WOL_HELPER_URL=http://host.docker.internal:8890
#WOL_BROADCAST_ADDR=255.255.255.255

# ── Web search (optional) ──────────────────────────────────────────────────────
# Real web search for the web.search tool. Without either of these, web.search
# falls back to DuckDuckGo instant answers (empty for most queries).
#  - SearXNG sidecar: add `search` to COMPOSE_PROFILES — that's the only step;
#    SEARXNG_URL already defaults to the sidecar. Set it only for an external
#    SearXNG instance:
#SEARXNG_URL=http://searxng:8080
#  - Or add a 'brave_api_key' secret in Settings → Secrets (Brave Search API).
