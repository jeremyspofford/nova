POSTGRES_PASSWORD=nova-dev-password
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OLLAMA_BASE_URL defaults to the bundled service (see note below)
LOG_LEVEL=INFO
# Instance-internal secret for the bundled SearXNG search service (no signup —
# any random string; e.g. `openssl rand -hex 16`)
SEARXNG_SECRET=change-me-random-string
# Local inference: `docker compose --profile inference up -d` starts bundled
# Ollama (OLLAMA_BASE_URL defaults to it). For host-run Ollama instead:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
