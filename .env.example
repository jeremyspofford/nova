# Nova AI Platform — Environment Configuration
# Run ./setup to configure interactively, or edit this file manually.

# ── Core ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
NOVA_ADMIN_SECRET=nova-admin-secret-change-me

# ── Local Inference ─────────────────────────────────────────────────────────
# Bundled (Nova-managed containers, opt-in via compose profiles — start/stop
# from Dashboard → Settings → Local Inference or ./install):
# COMPOSE_PROFILES=inference-ollama        # also: inference-vllm, inference-sglang, inference-llamacpp
#
# NVIDIA GPU acceleration for bundled containers (written by ./install after
# positive GPU detection; remove this line if `up` fails on a host without
# nvidia-container-toolkit):
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
#
# Model storage for bundled containers (defaults under ./data/models/;
# point at existing stores to reuse downloaded models):
# OLLAMA_MODELS_DIR=~/.ollama
# HF_CACHE_DIR=~/.cache/huggingface
# LLAMACPP_MODELS_DIR=./data/models/gguf
# LLAMACPP_MODEL=model.gguf
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# VLLM_GPU_MEMORY_UTILIZATION=0.90
# SGLANG_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# External (user-run server — Ollama/LM Studio/vLLM/SGLang/llama.cpp or any
# OpenAI-compatible endpoint; configure in Settings → Local Inference):
# OLLAMA_BASE_URL=host                     # Ollama on this machine, outside Docker
# OLLAMA_BASE_URL=http://192.168.1.50:11434  # remote GPU machine on LAN
#
# Routing: local-only | local-first | cloud-only | cloud-first
LLM_ROUTING_STRATEGY=local-first
# Default chat model — qwen2.5:7b is the recommended local default on 8GB+ VRAM.
# Override with any Ollama tag (llama3.2, phi4, etc.) or a cloud model ID
# (groq/llama-3.3-70b-versatile, chatgpt/gpt-4o, claude-sonnet-4-6, ...).
DEFAULT_CHAT_MODEL=qwen2.5:7b

# ── Data Directories (bind-mounted, immune to docker volume prune) ────
# POSTGRES_DATA_DIR=./data/postgres
# REDIS_DATA_DIR=./data/redis

# ── Embedding (memory-service) ──────────────────────────────────────────
# Primary model for vector embeddings. Fallback (text-embedding-005, Gemini free)
# is built-in — only override this if you want a different primary.
# EMBEDDING_MODEL=nomic-embed-text

# ── Per-provider default models (optional overrides) ──────────────────────
# DEFAULT_OLLAMA_MODEL=qwen2.5:7b
# DEFAULT_GROQ_MODEL=groq/llama-3.3-70b-versatile
# DEFAULT_GEMINI_MODEL=gemini/gemini-2.5-flash
# DEFAULT_CEREBRAS_MODEL=cerebras/llama3.1-8b
# DEFAULT_CHATGPT_MODEL=chatgpt/gpt-4o
# DEFAULT_OPENROUTER_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free
# DEFAULT_GITHUB_MODEL=github/gpt-4o-mini

# ── Wake-on-LAN (remote GPU only) ────────────────────────────────────────
# WOL_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
# WOL_BROADCAST_IP=192.168.1.255

# ── Subscription Providers (use your existing subscription) ───────────────
# ChatGPT Plus/Pro — run: codex login
CHATGPT_ACCESS_TOKEN=

# ── Free Tier Providers (no credit card required) ─────────────────────────
# NOTE: inline comments on the same line as a value become part of the value
#       (docker-compose .env parser). Keep comments on their own lines.

# https://console.groq.com
GROQ_API_KEY=
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_USE_ADC=false
# https://openrouter.ai
OPENROUTER_API_KEY=
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Paid API Keys (billed per token) ─────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# https://platform.openai.com
OPENAI_API_KEY=

# ── User Auth ────────────────────────────────────────────────────────────
# JWT_SECRET=               # Auto-generated if blank (stored in DB)
# REGISTRATION_MODE=open    # open | invite | admin
# GOOGLE_CLIENT_ID=         # Enable Google OAuth (optional)
# GOOGLE_CLIENT_SECRET=

# ── Workspace ───────────────────────────────────────────────────────────
# Directory Nova uses for working on repos, generated projects, etc.
# Mounted into the orchestrator container at /workspace.
# Default: ~/.nova/workspace (created automatically by setup.sh)
# NOVA_WORKSPACE=~/projects/my-app

# Home/Root sandbox tiers mount ${HOME} and / respectively into the container.
# HOME is detected automatically. No configuration needed for these tiers.

# ── Engram Memory ─────────────────────────────────────────────────────────
# Model used to decompose conversations into memory graph nodes.
# Default: auto (probes local models). Structured output quality matters here —
# weak models classify everything as "fact" and miss entities/preferences.
# Cloud-first:  groq/llama-3.3-70b-versatile  (free, best quality)
# Local-only:   qwen2.5:7b  (best structured output at 7B, ~4.4 GB VRAM)
# ENGRAM_DECOMPOSITION_MODEL=auto

# ── Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Auth enabled by default. Set to false for local dev without API keys.
REQUIRE_AUTH=true
SHELL_TIMEOUT_SECONDS=30

# ── CORS (comma-separated origins allowed to call backend APIs) ───────────
# Default covers local dev. Add your tunnel/Tailscale domain when using remote access.
# CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,http://localhost:8080

# ── Remote Access (optional) ─────────────────────────────────────────────
# Option A: Cloudflare Tunnel (browser access from anywhere, automatic HTTPS)
# 1. Create a tunnel: https://one.dash.cloudflare.com → Networks → Tunnels
# 2. Point it to http://dashboard:3000 (Docker internal hostname)
# 3. Paste the tunnel token below
# 4. Add "cloudflare-tunnel" to COMPOSE_PROFILES
# CLOUDFLARE_TUNNEL_TOKEN=

# Option B: Tailscale (fully private VPN mesh, encrypted WireGuard tunnel)
# 1. Create an auth key: https://login.tailscale.com/admin/settings/keys
# 2. Install Tailscale on your phone/laptop
# 3. Paste the auth key below
# 4. Add "tailscale" to COMPOSE_PROFILES
# TAILSCALE_AUTHKEY=

# ── Voice Service (enable with: docker compose --profile voice up) ───────────
# Uses OPENAI_API_KEY above for Whisper STT + OpenAI TTS by default
STT_PROVIDER=openai
TTS_PROVIDER=openai
# TTS_VOICE: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova
# TTS_MODEL: tts-1 (fast) or tts-1-hd (quality)
TTS_MODEL=tts-1

# ── Embedded Editor (optional, enable from Dashboard > Settings > Editor) ────
# EDITOR_FLAVOR: vscode or neovim
EDITOR_FLAVOR=vscode
# Directory mounted into editor
EDITOR_WORKSPACE=${HOME}/.nova/workspace
# VS Code settings/extensions (or ~/.vscode/ to reuse existing)
VSCODE_CONFIG_PATH=./data/editor-config/vscode
# Neovim config (or ~/.config/nvim/ to reuse existing)
NEOVIM_CONFIG_PATH=./data/editor-config/neovim
# Git repo cloned into config dir on startup (optional)
EDITOR_DOTFILES_REPO=

# ── Secrets Manager (optional, enable from Dashboard > Settings > Security) ──────
# VAULTWARDEN_ADMIN_TOKEN=   # Admin panel token for Vaultwarden (optional secrets manager)

# ── Knowledge Worker (optional, start with: docker compose --profile knowledge up) ──
# Auto-generated by setup.sh if blank
CREDENTIAL_MASTER_KEY=
MAX_CRAWL_PAGES=50
MAX_LLM_CALLS_PER_CRAWL=60

# ── Firecrawl (web scraping with JS rendering, add via MCP Integrations page) ──
# Cloud API — get a key at https://firecrawl.dev
# FIRECRAWL_API_KEY=
# Self-hosted — point to your own Firecrawl instance (no API key needed)
# FIRECRAWL_API_URL=http://localhost:3002

# ── Self-Modification (GitHub PR Gate) ─────────────────────────────────────
# Nova's own GitHub account for pushing branches and creating PRs.
# Requires a fine-grained PAT with Contents (read/write) and Pull Requests (read/write).
NOVA_GITHUB_PAT=
NOVA_GITHUB_REPO=arialabs/nova
NOVA_GITHUB_USER=
NOVA_GITHUB_EMAIL=
SELFMOD_RATE_LIMIT_PER_HOUR=5
SELFMOD_ENABLED=false
