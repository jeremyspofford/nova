POSTGRES_PASSWORD=nova-dev-password
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LOG_LEVEL=INFO

# Admin token — REQUIRED before exposing Nova beyond this machine
# (tailscale serve, tunnels). Empty = open, localhost-only dev.
# Generate one: openssl rand -hex 24
NOVA_AUTH_TOKEN=
# Instance-internal secret for the bundled SearXNG search service (no signup —
# any random string; e.g. `openssl rand -hex 16`)
SEARXNG_SECRET=change-me-random-string

# ── GPU (bundled Ollama) ────────────────────────────────────────────────
# The inference-control sidecar merges docker-compose.gpu.yml automatically
# when the docker NVIDIA runtime is present. OLLAMA_GPU=off opts out;
# OLLAMA_GPU=on forces it (e.g. Docker Desktop setups that support --gpus
# without advertising an nvidia runtime).
#OLLAMA_GPU=auto
# On NVIDIA machines, uncomment so manual host-side `docker compose`
# commands merge the same GPU override the sidecar uses:
#COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# ── Memory storage ──────────────────────────────────────────────────────
# Where Nova's markdown memory lives on the host. Any path plain files can
# live works: a NAS mount, an Obsidian vault folder, another disk. Restart
# with `docker compose up -d backend` after changing.
#NOVA_MEMORY_DIR=./data/memory
